// ─── Small Components ─────────────────────────────────────────────────────────

function Avatar({ member, size = 32 }) {
  return (
    <div style={{
      width:size, height:size, borderRadius:"50%",
      background:member.color, display:"flex", alignItems:"center",
      justifyContent:"center", fontSize:size*0.33, fontWeight:700,
      color:"#fff", flexShrink:0, fontFamily:"monospace",
      border:"2px solid rgba(255,255,255,0.15)", letterSpacing:-0.5,
    }}>{member.avatar}</div>
  );
}

function PlatformBadge({ platformId, small }) {
  const p = PLATFORMS.find(x => x.id === platformId);
  if (!p) return null;
  return (
    <span style={{
      display:"inline-flex", alignItems:"center", justifyContent:"center",
      width:small?20:26, height:small?20:26,
      borderRadius:6, background:p.color+"22",
      border:`1px solid ${p.color}44`, fontSize:small?10:12,
      color:p.color, fontWeight:800, flexShrink:0,
    }} title={p.label}>{p.icon}</span>
  );
}

function StatusBadge({ status }) {
  const s = STATUS_COLORS[status] || STATUS_COLORS.draft;
  return (
    <span style={{
      padding:"2px 10px", borderRadius:99, fontSize:11, fontWeight:600,
      background:s.bg, color:s.text, border:`1px solid ${s.border}`,
      textTransform:"capitalize", letterSpacing:0.3, whiteSpace:"nowrap",
    }}>{status}</span>
  );
}

function Modal({ children, onClose, wide }) {
  return (
    <div style={{
      position:"fixed", inset:0, background:"rgba(0,0,0,0.8)",
      zIndex:1000, display:"flex", alignItems:"center", justifyContent:"center",
      padding:20,
    }} onClick={e => { if (e.target === e.currentTarget) onClose(); }}>
      <div style={{
        background:"#110e1a", border:"1px solid #2a2040",
        borderRadius:18, maxWidth:wide?780:640, width:"100%",
        maxHeight:"92vh", overflowY:"auto",
        boxShadow:"0 24px 80px rgba(0,0,0,0.7)",
      }}>{children}</div>
    </div>
  );
}

// ─── AI Caption Generator ─────────────────────────────────────────────────────

function AICaptionPanel({ title, platforms, type, onSelect }) {
  const [topic, setTopic] = useState(title || "");
  const [tone, setTone] = useState("engaging");
  const [captions, setCaptions] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");

  const TONES = ["engaging","professional","playful","inspirational","urgent","storytelling"];

  const generate = async () => {
    if (!topic.trim()) return;
    setLoading(true); setError(""); setCaptions([]);
    try {
      const platformNames = platforms.map(id => PLATFORMS.find(p=>p.id===id)?.label).filter(Boolean).join(", ");
      const prompt = `You are a social media copywriter. Generate 3 distinct ${tone} captions for a ${type || "post"} about: "${topic}". 
Platforms: ${platformNames || "general social media"}.
Rules: Each caption should be platform-appropriate, include 2–3 relevant hashtags, and be under 280 characters.
Respond ONLY with a JSON array of 3 strings. No markdown, no preamble. Example: ["Caption 1 #tag","Caption 2 #tag","Caption 3 #tag"]`;

      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({
          model:"claude-sonnet-4-6",
          max_tokens:600,
          messages:[{ role:"user", content:prompt }],
        }),
      });
      const data = await res.json();
      const raw = data.content?.map(b=>b.text||"").join("").trim();
      const clean = raw.replace(/```json|```/g,"").trim();
      const parsed = JSON.parse(clean);
      setCaptions(Array.isArray(parsed) ? parsed : []);
    } catch(e) {
      setError("Caption generation failed. Check your connection and try again.");
    } finally { setLoading(false); }
  };

  return (
    <div style={{ background:"#0d0a17", borderRadius:14, padding:16, border:"1px solid #2a2040", marginBottom:16 }}>
      <div style={{ display:"flex", alignItems:"center", gap:8, marginBottom:12 }}>
        <span style={{ fontSize:16 }}>✨</span>
        <span style={{ fontSize:13, fontWeight:700, color:"#a855f7" }}>AI Caption Generator</span>
      </div>

      <label style={labelStyle}>Topic / Description</label>
      <input value={topic} onChange={e=>setTopic(e.target.value)}
        placeholder="What is this post about?" style={{...inputStyle, marginBottom:10}} />

      <label style={labelStyle}>Tone</label>
      <div style={{ display:"flex", gap:6, flexWrap:"wrap", marginBottom:12 }}>
        {TONES.map(t => (
          <button key={t} onClick={()=>setTone(t)} style={{
            padding:"4px 10px", borderRadius:7, cursor:"pointer", fontSize:11, fontWeight:600,
            border:`1px solid ${tone===t?"#7c3aed":"#2a2040"}`,
            background:tone===t?"#7c3aed22":"transparent",
            color:tone===t?"#a855f7":"#5a4f7a", textTransform:"capitalize",
          }}>{t}</button>
        ))}
      </div>

      <button onClick={generate} disabled={loading} style={{
        width:"100%", padding:"9px", borderRadius:9, border:"none", cursor:loading?"wait":"pointer",
        background:loading?"#2a2040":"linear-gradient(135deg,#7c3aed,#a855f7)",
        color:loading?"#5a4f7a":"#fff", fontSize:13, fontWeight:700,
        transition:"all 0.2s",
      }}>
        {loading ? "✨ Generating captions…" : "✨ Generate Captions"}
      </button>

      {error && <div style={{ fontSize:12, color:"#f87171", marginTop:8 }}>{error}</div>}

      {captions.length > 0 && (
        <div style={{ marginTop:12, display:"flex", flexDirection:"column", gap:8 }}>
          {captions.map((c,i) => (
            <div key={i} style={{
              background:"#16131f", borderRadius:10, padding:"10px 12px",
              border:"1px solid #2a2040", cursor:"pointer",
              transition:"border-color 0.15s",
            }}
              onMouseEnter={e=>e.currentTarget.style.borderColor="#7c3aed"}
              onMouseLeave={e=>e.currentTarget.style.borderColor="#2a2040"}
              onClick={()=>onSelect(c)}
            >
              <div style={{ fontSize:12, color:"#c4b5e0", lineHeight:1.6, marginBottom:6 }}>{c}</div>
              <button style={{
                fontSize:10, color:"#a855f7", background:"#7c3aed22",
                border:"1px solid #4c1d95", borderRadius:6, padding:"2px 8px", cursor:"pointer",
              }}>Use this caption →</button>
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

// ─── Post Card (drag-enabled) ─────────────────────────────────────────────────

function PostCard({ post, onClick, onDragStart, onDragEnd, dragging }) {
  const member = TEAM_MEMBERS.find(m => m.id === post.assignee);
  const s = STATUS_COLORS[post.status];
  return (
    <div
      draggable
      onDragStart={e => { e.dataTransfer.effectAllowed="move"; onDragStart(post); }}
      onDragEnd={onDragEnd}
      onClick={() => onClick(post)}
      style={{
        background: dragging ? "#1e1a2e" : "#16131f",
        border:`1px solid ${s.border}44`,
        borderRadius:12, padding:"13px 15px",
        cursor:"grab", transition:"all 0.18s",
        borderLeft:`3px solid ${s.text}`,
        opacity: dragging ? 0.5 : 1,
        userSelect:"none",
      }}
      onMouseEnter={e => { if(!dragging){ e.currentTarget.style.background="#1e1a2e"; e.currentTarget.style.transform="translateY(-2px)"; }}}
      onMouseLeave={e => { e.currentTarget.style.background="#16131f"; e.currentTarget.style.transform="none"; }}
    >
      <div style={{ display:"flex", justifyContent:"space-between", alignItems:"flex-start", gap:8, marginBottom:8 }}>
        <div style={{ fontWeight:600, fontSize:13, color:"#e2d9f3", lineHeight:1.3, flex:1 }}>{post.title}</div>
        <StatusBadge status={post.status} />
      </div>
      <div style={{ fontSize:12, color:"#7c6fa0", marginBottom:8, lineHeight:1.5 }}>
        {post.caption.slice(0,80)}{post.caption.length>80?"…":""}
      </div>
      <div style={{ display:"flex", alignItems:"center", justifyContent:"space-between", gap:8 }}>
        <div style={{ display:"flex", gap:4 }}>
          {post.platforms.map(p => <PlatformBadge key={p} platformId={p} small />)}
        </div>
        <div style={{ display:"flex", alignItems:"center", gap:8 }}>
          <span style={{ fontSize:11, color:"#5a4f7a" }}>{post.scheduledTime} · {post.scheduledDate?.slice(5)}</span>
          {member && <Avatar member={member} size={22} />}
        </div>
      </div>
    </div>
  );
}

// ─── Board with Drag & Drop ───────────────────────────────────────────────────

function BoardView({ posts, onPostClick, onStatusChange }) {
  const [draggingPost, setDraggingPost] = useState(null);
  const [dragOverStatus, setDragOverStatus] = useState(null);

  const handleDrop = (status) => {
    if (draggingPost && draggingPost.status !== status) {
      onStatusChange(draggingPost.id, status);
    }
    setDraggingPost(null);
    setDragOverStatus(null);
  };

  return (
    <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fit, minmax(230px, 1fr))", gap:16 }}>
      {Object.keys(STATUS_COLORS).map(status => {
        const sc = STATUS_COLORS[status];
        const colPosts = posts.filter(p => p.status === status);
        const isOver = dragOverStatus === status;
        return (
          <div
            key={status}
            onDragOver={e => { e.preventDefault(); setDragOverStatus(status); }}
            onDragLeave={() => setDragOverStatus(null)}
            onDrop={() => handleDrop(status)}
            style={{
              display:"flex", flexDirection:"column", gap:10,
              background: isOver ? sc.bg : "transparent",
              borderRadius:14, padding:isOver?"10px":0,
              border: isOver ? `2px dashed ${sc.text}` : "2px dashed transparent",
              transition:"all 0.15s", minHeight:200,
            }}
          >
            <div style={{ display:"flex", alignItems:"center", gap:8, paddingBottom:10, borderBottom:`1px solid ${sc.border}` }}>
              <span style={{ width:8, height:8, borderRadius:"50%", background:sc.text, flexShrink:0, boxShadow:`0 0 8px ${sc.text}` }} />
              <span style={{ fontSize:12, fontWeight:700, color:sc.text, textTransform:"capitalize", letterSpacing:0.3 }}>{status}</span>
              <span style={{ marginLeft:"auto", fontSize:11, color:"#3d3355", fontWeight:700 }}>{colPosts.length}</span>
            </div>
            {colPosts.map(p => (
              <PostCard
                key={p.id} post={p}
                onClick={onPostClick}
                onDragStart={setDraggingPost}
                onDragEnd={() => { setDraggingPost(null); setDragOverStatus(null); }}
                dragging={draggingPost?.id === p.id}
              />
            ))}
            {colPosts.length === 0 && (
              <div style={{
                fontSize:12, color: isOver ? sc.text : "#2d2645",
                textAlign:"center", padding:"24px 0", fontStyle:"italic",
                border: isOver ? "none" : "2px dashed #1a1628",
                borderRadius:10,
              }}>
                {isOver ? `Drop here to mark as ${status}` : "No posts yet"}
              </div>
            )}
          </div>
        );
      })}
    </div>
  );
}

